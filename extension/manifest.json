{ "manifest_version": 3, "name": "Force Background Tabs", "version": "1.0", "description": "Opens every link you click in a background tab.", "permissions": [ "tabs" ], "background": { "service_worker": "background.js" }, "content_scripts": [ { "matches": ["<all_urls>"], "js": ["content.js"], "run_at": "document_idle" } ] }